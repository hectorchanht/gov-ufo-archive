# lychee ignores — one regex per line.
# Hosts that block crawlers or rate-limit aggressively. These are official
# government catalog systems we link to but cannot reach from CI runners.
^https?://(www\.)?dgac\.gob\.cl/.*
^https?://sefaa\.dgac\.gob\.cl/.*
^https?://(www\.)?fab\.mil\.br/.*
^https?://www2\.fab\.mil\.br/.*
^https?://dibrarq\.arquivonacional\.gov\.br/.*
^https?://(www\.)?fau\.mil\.uy/.*
^https?://(www\.)?gob\.pe/fap.*
^https?://www\.argentina\.gob\.ar/.*
# YouTube embeds — sometimes 403 from CI IPs
^https?://(www\.)?youtube\.com/embed/.*
# DVIDS direct links — Akamai blocks data-center IPs
^https?://(www\.)?dvidshub\.net/.*
^https?://d34w7g4gy10iej\.cloudfront\.net/.*
# Gitignored PDF / video binaries — served from GitHub Releases at runtime
# but referenced as local hrefs in HTML. The files are absent on CI runners
# because they live in pdfs-v1 / videos-v1 release tags, not git.
^file:.*/pdfs/.*\.pdf$
^file:.*/videos/.*\.(mp4|mov|webm)$
^file:.*/bundles/.*$
# Government hosts that block crawlers, throttle aggressively, or fail
# TLS / HTTP/2 negotiation from GitHub Actions IPs.
^https?://(www\.)?sefaa\.cl/.*
^https?://(www\.)?planalto\.gov\.br/.*
^https?://(www\.)?bac-lac\.gc\.ca/.*
^https?://library-archives\.canada\.ca/.*
^https?://(www\.)?nationalarchives\.gov\.uk/.*
^https?://discovery\.nationalarchives\.gov\.uk/.*
^https?://(www\.)?aeronautica\.difesa\.it/.*
^https?://spotthestation\.nasa\.gov/.*
# TODO: FLIR1.mp4 / Gimbal.mp4 don't exist in videos-v1 — HTML references
# the canonical names but the release ships DOD_* official filenames.
# Skip until HTML uses correct asset names or release adds these aliases.
^https?://github\.com/hectorchanht/war-gov-ufo-release/releases/download/videos-v1/(FLIR1|Gimbal)\.mp4$
