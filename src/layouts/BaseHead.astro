---
// BaseHead.astro — every <head> element shared across all 15 archives.
// D-18 + CLAUDE.md §3.4 (shared favicon) + §13 (SW registration from BaseHead).
// Service-worker registration matches Phase 1 kill-switch invariant
// (research/PITFALLS.md Pitfall #1: { updateViaCache: 'none' }).
//
// Imports `../styles/global.css` so Astro bundles + emits the link tag in dist/.
// NO client:* directives — pure progressive enhancement (D-21..D-23).
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const { title, description, canonicalUrl, ogImage } = Astro.props;
const canonical = canonicalUrl ?? Astro.url.href;
const ogImg = ogImage ?? 'https://realufo.org/assets/og.svg';
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="theme-color" content="#0a0a0c" />

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

{/* Open Graph + Twitter — public-domain archive; no draft state per T-03-12. */}
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImg} />
<meta property="og:site_name" content="realufo.org" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImg} />

{/* CLAUDE.md §3.4 — shared classic-disk-UFO favicon (one source-of-truth). */}
<link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
<link rel="apple-touch-icon" href="/assets/favicon.svg" />

{/* Fonts — CLAUDE.md §3.3 (Source Serif 4 + JetBrains Mono ONLY).
    Preconnect lives here so DNS warm-up happens before paint. Phase 4 SW-07
    will swap this to self-hosted @fontsource/*; until then, the preconnect
    pair matches legacy index.html @ lines 45-47. */}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&display=swap"
  rel="stylesheet"
/>

{/* Service-worker registration — verbatim from legacy index.html line 26.
    research/PITFALLS.md Pitfall #1 / Phase 1 PMS-02 kill-switch:
      updateViaCache: 'none' is NON-NEGOTIABLE — without it the browser
      caches the SW script itself, defeating the kill-switch update path.
    `is:inline` per D-21..D-23 keeps the script verbatim — no Vite touch.
    The hard-coded literal '/sw.js' is the T-03-14 mitigation: no template
    variable here means no accidental URL drift across archives. */}
<script is:inline>
  if ("serviceWorker" in navigator) {
    window.addEventListener("load", function () {
      navigator.serviceWorker.register("/sw.js", { updateViaCache: 'none' }).catch(function () {});
    });
  }
</script>

{/* Umami analytics — remote `defer` script; deliberately NOT `is:inline`
    (the native `defer` semantics must apply). Mirrors legacy index.html line 28. */}
<script defer src="https://cloud.umami.is/script.js" data-website-id="9c4f36ef-30ad-4d76-947a-1724fe6acdba"></script>

{/* JSON-LD slot — Plan 03-05's wargov index.astro will emit Dataset schema.org
    structured data here when it consumes RootLayout. Slot left empty for now. */}
<slot name="head-extra" />
