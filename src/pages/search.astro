---
// src/pages/search.astro — Plan 04-19 Pagefind cross-archive search.
//
// Replaces the legacy Lunr-based /search.html (deleted in this same plan).
// Mounts PagefindUI Component UI against /pagefind/pagefind-ui.js +
// pagefind-ui.css which are emitted into dist/pagefind/ by
// `pnpm exec pagefind --site dist` at the tail of
// scripts/copy-legacy-archives.sh (postbuild — see Task 1 wiring).
//
// Compose:
//   - RootLayout (Plan 03-04) — archiveSlug='wargov' for tone-default.
//     This route lives at /search (no archive prefix) so the wargov
//     gold #d4a017 is the brand-consistent caution colour.
//   - PagefindUI mount via <script is:inline> (D-23 hydration-free).
//
// Search-result anchor injection (SRC-04 / RESEARCH §2 Pitfall 9):
//   PagefindUI's default URL output is the page URL only. To produce
//   deep links like `/aaro/#card-tic-tac-2004`, we override the
//   processResult callback to append result.sub_results[0].anchor.id
//   to result.url. This satisfies the URL contract from
//   .planning/phases/04-full-migration-search-offline-performance/
//   04-CONTEXT.md D-15.
//
// JS invariants preserved (CLAUDE.md §7):
//   - #7 — `/` keydown focuses search input. The PagefindUI input
//     gets `id="search-input"` injected so the global handler in
//     src/scripts/invariants.ts (Plan 03-04) Just Works.
//   - #8 — `?q=` URL persistence: bootstrap reads `?q=` on load and
//     pushes debounced updates so back/forward and shared links
//     round-trip. PagefindUI doesn't do this natively; we wire it
//     manually.
//
// D-21..D-23: every <script> here is <script is:inline>. NO client:*.
// D-26..D-28: no smartypants; verbatim hero copy preserved from the
// legacy /search.html (CLAUDE.md §9 fidelity rule).

import RootLayout from '../layouts/RootLayout.astro';

const title = 'Search every government UAP archive · realufo.org';
const description =
  'Cross-archive search of 4 active government UAP / UFO disclosure programmes — War.gov, AARO, NASA, NARA. Pagefind-powered, offline-capable, 0.001 % typo tolerance.';
const canonicalUrl = 'https://realufo.org/search';
---
<RootLayout
  title={title}
  description={description}
  archiveSlug="wargov"
  canonicalUrl={canonicalUrl}
>
  <link slot="head-extra" rel="stylesheet" href="/pagefind/pagefind-ui.css" />

  <section class="hero" id="intro" data-pagefind-ignore>
    <div class="container">
      <div class="coords">◉ INDEX · ARCHIVE · QUERY</div>
      <h1 class="hero-title">
        Search <em>every</em> government UAP archive
      </h1>
      <p class="hero-sub">
        4 official sources — one query. Pagefind WASM index, ~30&nbsp;KB initial
        load, lazy-fetched shards. Press <kbd>/</kbd> anywhere to focus.
      </p>
    </div>
  </section>

  <section class="search-container">
    <div class="container">
      <div id="pagefind-search"></div>
    </div>
  </section>

  {/* PagefindUI core — emitted into dist/pagefind/ by the postbuild
      pagefind invoke. Loaded via <script is:inline> (D-23 — no client:*
      hydration, no bundling). */}
  <script is:inline src="/pagefind/pagefind-ui.js"></script>

  <script is:inline>
    // PagefindUI mount — wait for the script and the DOM both ready.
    window.addEventListener('DOMContentLoaded', function () {
      // Defensive — PagefindUI ships as a global; if /pagefind/pagefind-ui.js
      // 404s (dist not regenerated), the mount silently no-ops so the page
      // still loads.
      if (typeof PagefindUI !== 'function') return;

      var pfui = new PagefindUI({
        element: '#pagefind-search',
        showSubResults: true,
        showImages: false,
        // SRC-03 — per-archive filter UI (RESEARCH §2). Pagefind renders
        // each declared filter as a chip group beneath the search input.
        // Multi-filter is comma-separated in data-pagefind-filter; the
        // UI reads them apart.
        filters: { archive: 'Archive', type: 'Type', agency: 'Agency' },
        translations: { placeholder: 'Search 4 archives — wargov, aaro, nasa, nara…' },
        // SRC-04 (RESEARCH §2 Pitfall 9) — anchor injection. PagefindUI's
        // default URL output is the page URL only. We mutate result.url
        // (and each sub_result.url) to append #card-<slug> from the
        // closest indexed-anchor ancestor's id. This makes shareable deep
        // links land directly on the matched card.
        processResult: function (result) {
          // Each result has result.url + result.sub_results[].url. The
          // anchor.id on a sub_result points at the nearest id ancestor
          // of the match. For us that's `<article id="card-<slug>">`.
          if (Array.isArray(result.sub_results)) {
            result.sub_results.forEach(function (sr) {
              if (sr && sr.anchor && sr.anchor.id) {
                // Strip any existing fragment, then re-append.
                var base = (sr.url || result.url || '').split('#')[0];
                sr.url = base + '#' + sr.anchor.id;
              }
            });
            // Promote the first sub_result's anchor to the parent
            // result.url so the headline link is also deep-linked.
            if (result.sub_results.length > 0 && result.sub_results[0].url) {
              result.url = result.sub_results[0].url;
            }
          }
          return result;
        },
      });

      // Best-effort: tag the PagefindUI search input with id="search-input"
      // so CLAUDE.md §7 invariant #7 (/-focus) keeps working without
      // changes to invariants.ts.
      var input = document.querySelector(
        '#pagefind-search .pagefind-ui__search-input',
      );
      if (input && !input.id) input.id = 'search-input';

      // CLAUDE.md §7 invariant #8 — ?q= URL persistence.
      // Read ?q= on load, push debounced updates back into the URL.
      try {
        var params = new URLSearchParams(location.search);
        var q0 = params.get('q');
        if (q0 && input) {
          input.value = q0;
          // Triggering 'input' makes PagefindUI re-query.
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
        if (input) {
          var pushT;
          input.addEventListener('input', function () {
            clearTimeout(pushT);
            pushT = setTimeout(function () {
              var v = input.value;
              var p = new URLSearchParams(location.search);
              if (v) p.set('q', v);
              else p.delete('q');
              var qs = p.toString();
              var newUrl = location.pathname + (qs ? '?' + qs : '');
              history.replaceState(null, '', newUrl);
            }, 250);
          });
        }
      } catch (_) {
        // ?q= persistence is a nice-to-have; never break the page on it.
      }
    });
  </script>

  <style>
    .search-container {
      padding: 32px 0 80px;
    }
    .search-container .container {
      max-width: 960px;
      margin: 0 auto;
      padding: 0 16px;
    }
    /* PagefindUI tone-colour overrides — match wargov gold (--caution
       inherited from RootLayout). Keep the rest of the default Pagefind
       styling for layout consistency across versions. */
    #pagefind-search {
      --pagefind-ui-primary: var(--caution);
      --pagefind-ui-text: var(--ink);
      --pagefind-ui-background: var(--bg-2);
      --pagefind-ui-border: var(--rule);
      --pagefind-ui-tag: var(--panel);
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 4px;
      --pagefind-ui-font: var(--serif);
    }
  </style>
</RootLayout>
