---
// Footer.astro — Source list + public-domain license per archive
// (CLAUDE.md §4 footer block + §4.1 + §9 + D-20).
//
// CLAUDE.md §9 (public-domain attribution per jurisdiction) is VERBATIM:
// every license string below is copy-pasted from the spec — no paraphrase.
// Footer external-source links DO use the inline ↗ marker (CLAUDE.md §11
// don't applies only to HEADER nav links).

import type { ArchiveSlug } from '../layouts/RootLayout.astro';

interface Props {
  archiveSlug: ArchiveSlug;
  /** Optional record count to render in the colophon strip. */
  totalRecords?: number;
  /** Optional ISO date (YYYY-MM-DD) of last build for the colophon. */
  lastUpdated?: string;
}

const { archiveSlug, totalRecords, lastUpdated } = Astro.props;

// Public-domain attribution per CLAUDE.md §9 — verbatim. The US-jurisdiction
// archives (wargov, aaro, nasa, nara) share 17 U.S.C. § 105.
const LICENSE: Record<ArchiveSlug, string> = {
  wargov:    '17 U.S.C. § 105',
  aaro:      '17 U.S.C. § 105',
  nasa:      '17 U.S.C. § 105',
  nara:      '17 U.S.C. § 105',
  geipan:    'Loi n° 78-753 (Information Publique)',
  uk:        'Open Government Licence v3',
  brazil:    'Lei nº 12.527/2011 (LAI)',
  chile:     'Ley nº 20.285 sobre Acceso a la Información Pública',
  argentina: 'Ley nº 27.275 (Acceso a la Información Pública)',
  italy:     'D.lgs. 33/2013 (FOIA)',
  spain:     'Ley 19/2013 (Transparencia)',
  uruguay:   'Ley nº 18.381',
  canada:    'Public works produced by the Crown (LAC)',
  nz:        'Crown Copyright (NZDF)',
  peru:      'Public domain — Gobierno del Perú',
};

// Per-archive official source URL — CLAUDE.md §2 table verbatim.
const SOURCE_URLS: Record<ArchiveSlug, { name: string; url: string }> = {
  wargov:    { name: 'war.gov / UFO',                 url: 'https://www.war.gov/UFO/' },
  aaro:      { name: 'AARO.mil',                      url: 'https://www.aaro.mil/' },
  nasa:      { name: 'NASA UAP Study',                url: 'https://science.nasa.gov/uap/' },
  nara:      { name: 'National Archives Catalog',     url: 'https://catalog.archives.gov/' },
  geipan:    { name: 'GEIPAN (CNES)',                 url: 'https://www.cnes-geipan.fr/' },
  uk:        { name: 'UK National Archives',          url: 'https://discovery.nationalarchives.gov.uk/' },
  brazil:    { name: 'Força Aérea Brasileira',        url: 'https://www.fab.mil.br/' },
  chile:     { name: 'Chile SEFAA (DGAC)',            url: 'https://www.sefaa.cl/' },
  argentina: { name: 'CEFAe (Fuerza Aérea Argentina)',url: 'https://www.argentina.gob.ar/fuerzaaerea/cefae' },
  canada:    { name: 'Library & Archives Canada',     url: 'https://www.bac-lac.gc.ca/' },
  italy:     { name: 'Aeronautica Militare',          url: 'https://www.aeronautica.difesa.it/' },
  nz:        { name: 'NZ Defence Force',              url: 'https://www.nzdf.mil.nz/' },
  peru:      { name: 'Peru FAP (OIFAA)',              url: 'https://www.gob.pe/fap' },
  spain:     { name: 'Ejército del Aire',             url: 'https://ejercitodelaire.defensa.gob.es/' },
  uruguay:   { name: 'FAU (CRIDOVNI)',                url: 'https://www.fau.mil.uy/' },
};

const license = LICENSE[archiveSlug] ?? LICENSE.wargov;
const primarySource = SOURCE_URLS[archiveSlug];

// All other archives, with the active one removed — supports the "sibling
// archives" column.
const siblings = (Object.keys(SOURCE_URLS) as ArchiveSlug[]).filter((s) => s !== archiveSlug);

// CLAUDE.md §2 paths (must match Nav.astro for cross-link parity).
const PATH: Record<ArchiveSlug, string> = {
  wargov: '/', aaro: '/aaro/', nasa: '/nasa/', nara: '/nara/',
  geipan: '/geipan/', uk: '/uk/', brazil: '/brazil/', chile: '/chile/',
  argentina: '/argentina/', canada: '/canada/', italy: '/italy/',
  nz: '/nz/', peru: '/peru/', spain: '/spain/', uruguay: '/uruguay/',
};
---

<footer>
  <div class="container">
    <div class="footer-grid">
      <div>
        <h4>About</h4>
        <p class="about">
          realufo.org — offline-first archive of every official government UAP source.
          Faithful, verbatim, mobile-first. Public-domain materials only.
        </p>
      </div>

      <div>
        <h4>Source</h4>
        <ul>
          {/* Active-archive official source first per CLAUDE.md §4.1.
              External link → inline ↗ marker per CLAUDE.md §11 (header rule
              forbids it; footer source list permits + encourages it). */}
          <li>
            <a href={primarySource.url} target="_blank" rel="noopener">
              {primarySource.name} ↗
            </a>
          </li>
          {/* Other 14 source URLs follow — CLAUDE.md §4.1 (Source = official
              URLs only; never internal mirror paths). */}
          {siblings.map((s) => (
            <li>
              <a href={SOURCE_URLS[s].url} target="_blank" rel="noopener">
                {SOURCE_URLS[s].name} ↗
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4>License</h4>
        <p class="license">
          Public domain — {license}
        </p>
        <p class="license-note">
          All materials in this archive are released by their originating governments
          under their respective public-information statutes. realufo.org provides no
          additional copyright claim.
        </p>
      </div>

      <div>
        <h4>Archives</h4>
        <ul>
          <li><a href="/">War.gov</a></li>
          {(Object.keys(PATH) as ArchiveSlug[])
            .filter((s) => s !== 'wargov')
            .map((s) => (
              <li><a href={PATH[s]}>{SOURCE_URLS[s].name}</a></li>
            ))}
        </ul>
      </div>
    </div>

    <div class="colophon">
      <span>
        {totalRecords !== undefined ? `${totalRecords} records` : 'realufo.org'}
        {' · For research and reference'}
      </span>
      <span>
        {lastUpdated ? `Last updated ${lastUpdated}` : 'Built from public source'}
      </span>
    </div>
  </div>
</footer>

<style>
  /* footer base layout lives in global.css; this scoped block tightens the
     per-archive about + license-note copy without overriding the grid. */
  .about,
  .license-note {
    color: var(--ink-dim);
    font-family: var(--serif);
    font-size: 13px;
    line-height: 1.5;
    margin-top: 8px;
  }

  .license {
    color: var(--ink);
    font-family: var(--serif);
    font-size: 14px;
    line-height: 1.55;
  }

  .license-note {
    font-size: 11px;
    color: var(--ink-faint);
  }
</style>
