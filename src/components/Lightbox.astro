---
// Lightbox.astro — static shell markup matching CLAUDE.md §4 + the legacy
// index.html @ lines 1487-1494. NO frontmatter logic; the openAt() /
// navLb() / closeLb() handlers live in src/scripts/invariants.ts (Plan
// 03-04), already inlined by RootLayout.astro's bottom-of-body
// `<script is:inline set:html={INVARIANTS_JS}>` block.
//
// IDs used here MUST match the IDs the invariants module queries:
//   #lightbox    (the .lightbox container)
//   #lb-rotate   (rotate-to-landscape button, mobile)
//   #lb-close    (close button — bound by invariants.ts line ~123)
//   #lb-prev     (previous nav — invariants.ts line ~124)
//   #lb-next     (next nav — invariants.ts line ~125)
//   #lb-counter  (1 / N counter)
//   #lb-inner    (the asset render target — image / video / iframe)
//   #lb-meta     (NEW 2026-05-28 — description + agency + date + region +
//                 category panel rendered from window.__lbList entries)
//   #lb-actions  (NEW 2026-05-28 — dual action buttons: Download from
//                 realufo + View on original source)
//
// .open class triggers display:flex via global.css (Plan 03-04 line 365).
// Mobile sizing (40×40 nav buttons + edge-pinned) is in global.css per
// CLAUDE.md §8.
//
// Asset-type coverage (renderLb() in invariants.ts handles all 7):
//   PDF      → iframe (local) OR new-tab link (remote, via Download button)
//   VID      → <video controls> + dual <source> children (local + remote)
//   IMG      → <img> with onerror fallback to remote
//   AUDIO    → <audio controls> + <source>
//   CATALOG  → text-only meta panel + Download/Source buttons route external
//   CASE     → iframe rendering the case detail HTML page
//   PAGE     → iframe rendering the legacy long-form text page
//
// SCOPE PIVOT (2026-05-28): all 4 active archives share this Lightbox
// shell. The CatalogCard.astro + Card.astro contracts both emit data-desc,
// data-agency, data-date, data-region, data-category, data-src on the
// <article> element; refreshLbList() in each per-archive page reads these
// into window.__lbList so renderLb() can populate the meta panel + action
// buttons without per-archive customisation.
---
<div class="lightbox" id="lightbox" aria-hidden="true">
  {/* Top-left tools cluster — rotate + fullscreen. Operator spec 2026-05-29:
      both buttons always visible (not mobile-only), z-index above prev/next
      and meta-panel. Fullscreen calls lightbox.requestFullscreen() and the
      JS in invariants.ts toggles the label on `fullscreenchange`. */}
  <button class="lb-rotate" id="lb-rotate" aria-label="Rotate view" title="Rotate" type="button">⟳</button>
  <button class="lb-fullscreen" id="lb-fullscreen" aria-label="Enter fullscreen" title="Fullscreen" type="button">⛶</button>
  <div class="lb-close" id="lb-close" role="button" tabindex="0" aria-label="Close (Escape)">×</div>
  <button class="lb-nav prev" id="lb-prev" aria-label="Previous (←)" type="button">‹</button>
  <button class="lb-nav next" id="lb-next" aria-label="Next (→)" type="button">›</button>
  <div class="lb-counter" id="lb-counter"></div>
  <div class="lb-frame">
    <div class="lightbox-inner" id="lb-inner"></div>
    {/* Meta panel — populated by renderLb() from window.__lbList[lbIdx].
        Fields: title (h3), desc (p), then dl with agency / date / region /
        category. Empty fields are omitted so cards with sparse metadata
        don't render hollow rows. CLAUDE.md §9 "no filler" — empty desc =
        no <p>, not a placeholder string. */}
    <div class="lb-meta-panel" id="lb-meta" aria-live="polite"></div>
    {/* Dual action buttons per operator spec 2026-05-28:
          - Download from realufo (uses lbList[i].local || lbList[i].url,
            falls back to .url; R2 URL when card.local empty + url is R2)
          - View on original source (uses lbList[i].source, the official
            archive page URL — opens in new tab with rel=noopener)
        Buttons are populated/hidden by renderLb(); a button with an empty
        href is hidden via aria-hidden + display:none so cards lacking a
        source or download URL don't show a broken link. */}
    <div class="lb-actions" id="lb-actions">
      <a class="lb-btn lb-btn-download" id="lb-download" href="#" download rel="noopener">Download</a>
      <a class="lb-btn lb-btn-source" id="lb-source" href="#" target="_blank" rel="noopener">View on source ↗</a>
    </div>
  </div>
</div>

<style is:global>
  /* is:global — REQUIRED. Lightbox child elements (iframe, dl, dt, dd,
     img, video, audio) are runtime-injected via lbInner.innerHTML in
     invariants.ts, so they don't carry the data-astro-cid-* scope
     attribute. Without is:global, scoped selectors compiled like
     `.lb-meta-panel[data-astro-cid-...] dl[data-astro-cid-...]` would
     never match runtime-injected children — dl falls back to default
     block layout (dt+dd each on own line) and iframe collapses to its
     intrinsic 300x150 default. 2026-05-29 regression fix.

     Selector ergonomics: every rule below is prefixed with `.lightbox`
     or `.lb-*` so it can't accidentally bleed into unrelated DOM. */
  /* Scoped polish layered atop global.css's .lightbox base. The base lives
     in src/styles/global.css (Plan 03-04 lines 355-399); this block adds
     the counter + inner sizing per CLAUDE.md §8 + index.html @ ~line 775.

     Operator spec 2026-05-29 — z-index hierarchy (top-most first):
       lb-close            > 6  (top-right, must clear lb-nav per spec 7)
       lb-rotate, lb-fs    > 5
       lb-nav prev/next    > 4  (above meta-panel per spec 7)
       lb-counter          > 3
       lb-meta-panel       > 2  (desc box pinned to bottom)
       lightbox-inner      > 1  (asset render target — fills remaining space)
  */
  .lb-counter {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--ink-dim);
    background: rgba(17, 17, 20, 0.8);
    padding: 6px 12px;
    border-radius: 4px;
    border: 1px solid var(--rule);
    z-index: 3;
  }

  /* Frame fills the viewport and stacks asset (top, fills) + meta-panel
     (bottom, pinned). Operator spec 2026-05-29: desc box at bottom of
     viewport (spec 9); asset area takes the rest. The meta-panel is
     `margin-top: auto` so the asset expands above it. */
  .lb-frame {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: flex-start;
    gap: 8px;
    width: 100vw;
    height: 100vh;
    max-width: 100vw;
    max-height: 100vh;
    padding: 56px 8px 8px;        /* top: clear of close/rotate/fullscreen chrome */
    position: relative;
    z-index: 1;
  }

  /* Asset render target — fills the available space ABOVE the meta-panel.
     PDF iframe + image + video all share the same dimensions per operator
     spec 5 ("PDF iframe should occupy as much vertical space as image/
     video does"). */
  .lightbox-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1 1 auto;
    min-height: 0;                 /* allow flex children to shrink past content */
    width: 100%;
    overflow: hidden;
  }

  .lightbox-inner img,
  .lightbox-inner video {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    border: 1px solid var(--rule-strong);
    background: var(--bg-2);
    object-fit: contain;
  }

  /* PDF iframe — fills the asset area to match image/video sizing.
     Operator spec 5: same vertical real-estate as IMG/VID. The
     `align-self: stretch` + `flex: 1 1 auto` overrides the parent
     `.lightbox-inner`'s `align-items: center` for THIS child only —
     image/video keep intrinsic centering, iframe stretches to fill.
     Without these, the iframe collapses to its default ~300×150
     intrinsic size inside the flex container (2026-05-29 fix). */
  .lightbox-inner iframe {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    flex: 1 1 auto;
    align-self: stretch;
    border: 1px solid var(--rule-strong);
    background: var(--bg-2);
  }

  .lightbox-inner audio {
    width: min(96vw, 900px);
  }

  /* Meta panel — dark card with serif description + mono metadata dl.
     Operator spec 9 (2026-05-29): pinned to bottom of viewport via
     margin-top: auto in the flex column. Capped at 30vh on mobile so
     the asset still gets ≥ 70vh. CLAUDE.md §3.2 palette + §3.3 typography. */
  .lb-meta-panel {
    background: var(--bg-2);
    border: 1px solid var(--rule);
    color: var(--ink);
    padding: 10px 14px;
    font-family: var(--serif);
    font-size: 13px;
    line-height: 1.45;
    width: 100%;
    max-width: 100%;
    max-height: 22vh;
    overflow-y: auto;
    flex: 0 0 auto;
    margin-top: auto;              /* pin to bottom of the flex column */
    z-index: 2;
  }

  .lb-meta-panel:empty {
    display: none;
  }

  .lb-meta-panel h3 {
    margin: 0 0 6px;
    font-family: var(--serif);
    font-size: 16px;
    color: var(--ink);
  }

  .lb-meta-panel p {
    margin: 0 0 8px;
    color: var(--ink-dim);
  }

  .lb-meta-panel dl {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 4px 12px;
    margin: 0;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
  }

  .lb-meta-panel dt {
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .lb-meta-panel dd {
    margin: 0;
    color: var(--ink-dim);
    overflow-wrap: anywhere; /* CLAUDE.md §8 — long titles never overflow */
  }

  /* Dual action buttons — Download (R2 / local) + View on source (external).
     CLAUDE.md §8 44 px touch targets. The wargov gold (--caution) accent
     marks both as primary actions. */
  .lb-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
  }

  .lb-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 10px 16px;
    border: 1px solid var(--rule-strong);
    background: var(--bg-2);
    color: var(--ink);
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: border-color 120ms ease, color 120ms ease;
  }

  .lb-btn:hover,
  .lb-btn:focus-visible {
    border-color: var(--caution);
    color: var(--caution);
  }

  .lb-btn[aria-hidden="true"],
  .lb-btn[hidden] {
    display: none;
  }

  /* Top-left tools cluster — rotate (left-most) + fullscreen (right of rotate).
     Operator spec 2026-05-29 (spec 10): both buttons ALWAYS visible (not
     mobile-only). z-index 5 — above prev/next (4) and meta-panel (2). */
  .lb-rotate,
  .lb-fullscreen {
    position: absolute;
    top: 12px;
    width: 44px;
    height: 44px;
    background: var(--bg-2);
    border: 1px solid var(--rule-strong);
    border-radius: 50%;
    color: var(--ink);
    font-size: 18px;
    cursor: pointer;
    display: grid;
    place-items: center;
    z-index: 5;
    padding: 0;
    line-height: 1;
  }
  .lb-rotate     { left: 12px; }
  .lb-fullscreen { left: 64px; }

  .lb-rotate:hover,
  .lb-rotate:focus-visible,
  .lb-fullscreen:hover,
  .lb-fullscreen:focus-visible {
    border-color: var(--caution);
    color: var(--caution);
  }

  @media (max-width: 720px) {
    .lb-rotate,
    .lb-fullscreen {
      width: 40px;
      height: 40px;
      font-size: 16px;
    }
    .lb-rotate     { left: 8px; top: 8px; }
    .lb-fullscreen { left: 56px; top: 8px; }
    .lb-meta-panel {
      font-size: 13px;
      padding: 10px 12px;
      max-height: 30vh;            /* spec 9 — mobile cap */
    }
    .lb-frame {
      padding: 52px 4px 4px;
    }
    .lb-actions {
      justify-content: stretch;
    }
    .lb-btn {
      flex: 1 1 auto;
      padding: 10px 12px;
      font-size: 11px;
    }
  }

  .lightbox.lb-rotated .lightbox-inner img,
  .lightbox.lb-rotated .lightbox-inner video {
    transform: rotate(90deg);
    transform-origin: center;
    max-width: 86vh;
    max-height: 92vw;
  }
</style>
