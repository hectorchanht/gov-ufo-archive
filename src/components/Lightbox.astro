---
// Lightbox.astro — static shell markup matching CLAUDE.md §4 + the legacy
// index.html @ lines 1487-1494. NO frontmatter logic; the openAt() /
// navLb() / closeLb() handlers live in src/scripts/invariants.ts (Plan
// 03-04), already inlined by RootLayout.astro's bottom-of-body
// `<script is:inline set:html={INVARIANTS_JS}>` block.
//
// IDs used here MUST match the IDs the invariants module queries:
//   #lightbox    (the .lightbox container)
//   #lb-rotate   (rotate-to-landscape button, mobile)
//   #lb-close    (close button — bound by invariants.ts line ~123)
//   #lb-prev     (previous nav — invariants.ts line ~124)
//   #lb-next     (next nav — invariants.ts line ~125)
//   #lb-counter  (1 / N counter)
//   #lb-inner    (the asset render target — image / video / iframe)
//   #lb-meta     (NEW 2026-05-28 — description + agency + date + region +
//                 category panel rendered from window.__lbList entries)
//   #lb-actions  (NEW 2026-05-28 — dual action buttons: Download from
//                 realufo + View on original source)
//
// .open class triggers display:flex via global.css (Plan 03-04 line 365).
// Mobile sizing (40×40 nav buttons + edge-pinned) is in global.css per
// CLAUDE.md §8.
//
// Asset-type coverage (renderLb() in invariants.ts handles all 7):
//   PDF      → iframe (local) OR new-tab link (remote, via Download button)
//   VID      → <video controls> + dual <source> children (local + remote)
//   IMG      → <img> with onerror fallback to remote
//   AUDIO    → <audio controls> + <source>
//   CATALOG  → text-only meta panel + Download/Source buttons route external
//   CASE     → iframe rendering the case detail HTML page
//   PAGE     → iframe rendering the legacy long-form text page
//
// SCOPE PIVOT (2026-05-28): all 4 active archives share this Lightbox
// shell. The CatalogCard.astro + Card.astro contracts both emit data-desc,
// data-agency, data-date, data-region, data-category, data-src on the
// <article> element; refreshLbList() in each per-archive page reads these
// into window.__lbList so renderLb() can populate the meta panel + action
// buttons without per-archive customisation.
---
<div class="lightbox" id="lightbox" aria-hidden="true">
  <button class="lb-rotate" id="lb-rotate" aria-label="Rotate view" title="Rotate" type="button">⟳</button>
  <div class="lb-close" id="lb-close" role="button" tabindex="0" aria-label="Close (Escape)">×</div>
  <button class="lb-nav prev" id="lb-prev" aria-label="Previous (←)" type="button">‹</button>
  <button class="lb-nav next" id="lb-next" aria-label="Next (→)" type="button">›</button>
  <div class="lb-counter" id="lb-counter"></div>
  <div class="lb-frame">
    <div class="lightbox-inner" id="lb-inner"></div>
    {/* Meta panel — populated by renderLb() from window.__lbList[lbIdx].
        Fields: title (h3), desc (p), then dl with agency / date / region /
        category. Empty fields are omitted so cards with sparse metadata
        don't render hollow rows. CLAUDE.md §9 "no filler" — empty desc =
        no <p>, not a placeholder string. */}
    <div class="lb-meta-panel" id="lb-meta" aria-live="polite"></div>
    {/* Dual action buttons per operator spec 2026-05-28:
          - Download from realufo (uses lbList[i].local || lbList[i].url,
            falls back to .url; R2 URL when card.local empty + url is R2)
          - View on original source (uses lbList[i].source, the official
            archive page URL — opens in new tab with rel=noopener)
        Buttons are populated/hidden by renderLb(); a button with an empty
        href is hidden via aria-hidden + display:none so cards lacking a
        source or download URL don't show a broken link. */}
    <div class="lb-actions" id="lb-actions">
      <a class="lb-btn lb-btn-download" id="lb-download" href="#" download rel="noopener">Download</a>
      <a class="lb-btn lb-btn-source" id="lb-source" href="#" target="_blank" rel="noopener">View on source ↗</a>
    </div>
  </div>
</div>

<style>
  /* Scoped polish layered atop global.css's .lightbox base. The base lives
     in src/styles/global.css (Plan 03-04 lines 355-399); this block adds
     the counter + inner sizing per CLAUDE.md §8 + index.html @ ~line 775. */
  .lb-counter {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--ink-dim);
    background: rgba(17, 17, 20, 0.8);
    padding: 6px 12px;
    border-radius: 4px;
    border: 1px solid var(--rule);
    z-index: 3;
  }

  /* Frame wraps asset render target + meta panel + action buttons so the
     three stack vertically inside the viewport.
     Operator 2026-05-28: asset view sized "as big as possible".
     1280px cap removed; only viewport limits asset width now.
     Asset gets 82vh (was 70vh); meta-panel + actions fit in remaining
     ~14vh + chrome. .lb-frame fills 96vw on large desktops. */
  .lb-frame {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: center;
    gap: 8px;
    max-width: 96vw;
    max-height: 96vh;
    position: relative;
    z-index: 2;
  }

  .lightbox-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    max-height: 82vh;
    flex: 1 1 auto;
  }

  .lightbox-inner img,
  .lightbox-inner video {
    max-width: 96vw;
    max-height: 82vh;
    width: auto;
    height: auto;
    border: 1px solid var(--rule-strong);
    background: var(--bg-2);
  }

  .lightbox-inner iframe {
    width: 96vw;
    height: 82vh;
    max-width: 96vw;
    max-height: 82vh;
    border: 1px solid var(--rule-strong);
    background: var(--bg-2);
  }

  .lightbox-inner audio {
    width: min(96vw, 900px);
  }

  /* Meta panel — dark card with serif description + mono metadata dl.
     CLAUDE.md §3.2 palette + §3.3 typography rules. Mobile-first: tight
     padding on 360 px viewport, looser at 720 px+. */
  .lb-meta-panel {
    background: var(--bg-2);
    border: 1px solid var(--rule);
    color: var(--ink);
    padding: 8px 14px;
    font-family: var(--serif);
    font-size: 13px;
    line-height: 1.45;
    max-width: 100%;
    overflow-y: auto;
    /* Compact — operator 2026-05-28 wants asset as big as possible. */
    max-height: 12vh;
    flex: 0 0 auto;
  }

  .lb-meta-panel:empty {
    display: none;
  }

  .lb-meta-panel h3 {
    margin: 0 0 6px;
    font-family: var(--serif);
    font-size: 16px;
    color: var(--ink);
  }

  .lb-meta-panel p {
    margin: 0 0 8px;
    color: var(--ink-dim);
  }

  .lb-meta-panel dl {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 4px 12px;
    margin: 0;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
  }

  .lb-meta-panel dt {
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .lb-meta-panel dd {
    margin: 0;
    color: var(--ink-dim);
    overflow-wrap: anywhere; /* CLAUDE.md §8 — long titles never overflow */
  }

  /* Dual action buttons — Download (R2 / local) + View on source (external).
     CLAUDE.md §8 44 px touch targets. The wargov gold (--caution) accent
     marks both as primary actions. */
  .lb-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
  }

  .lb-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 10px 16px;
    border: 1px solid var(--rule-strong);
    background: var(--bg-2);
    color: var(--ink);
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: border-color 120ms ease, color 120ms ease;
  }

  .lb-btn:hover,
  .lb-btn:focus-visible {
    border-color: var(--caution);
    color: var(--caution);
  }

  .lb-btn[aria-hidden="true"],
  .lb-btn[hidden] {
    display: none;
  }

  /* CLAUDE.md §8 — rotate-to-landscape is mobile-only and only when the
     lightbox is open. The .lb-rotated class is toggled by future JS. */
  .lb-rotate {
    display: none;
    position: absolute;
    top: 12px;
    right: 64px;
    width: 44px;
    height: 44px;
    background: var(--bg-2);
    border: 1px solid var(--rule-strong);
    border-radius: 50%;
    color: var(--ink);
    font-size: 18px;
    cursor: pointer;
    place-items: center;
    z-index: 3;
  }

  @media (max-width: 720px) {
    .lightbox.open .lb-rotate { display: grid; }
    .lb-frame {
      max-height: 96vh;
    }
    .lb-meta-panel {
      font-size: 13px;
      padding: 10px 12px;
      max-height: 30vh;
    }
    .lb-actions {
      justify-content: stretch;
    }
    .lb-btn {
      flex: 1 1 auto;
      padding: 10px 12px;
      font-size: 11px;
    }
  }

  .lightbox.lb-rotated .lightbox-inner img,
  .lightbox.lb-rotated .lightbox-inner video {
    transform: rotate(90deg);
    transform-origin: center;
    max-width: 86vh;
    max-height: 92vw;
  }
</style>
