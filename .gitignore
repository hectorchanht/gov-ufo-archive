# ============================================================
# OFFLINE MIRROR — large files excluded from Git
# Run ./scripts/sync.sh after clone to populate locally.
# ============================================================

# Bundle archives (big zips)
bundles/Release_1.zip
bundles/uapvideos.zip

# DVIDS / DOD bulk videos — ALL excluded from git.
# Site streams them from the videos-v1 GitHub Release instead:
#   https://github.com/hectorchanht/war-gov-ufo-release/releases/tag/videos-v1
bundles/uapvideos/

# PDFs all moved to GitHub Releases (pdfs-v1) — the repo keeps only
# images for fast page loads. Source: ./scripts/sync.sh re-populates.
bundles/Release_1/*.pdf
aaro-mirror/pdfs/
nasa-mirror/pdfs/
nara-mirror/pdfs/

# Local extraction cache
download.zip

# AARO official UAP videos (cloudfront, often >100 MB)
aaro-mirror/videos/

# Build / runtime artifacts
.DS_Store
__pycache__/
*.pyc
.venv/
venv/
node_modules/

# Generated manifest cache (rebuilt by scripts)
.cache/

# Editor cruft
.vscode/
.idea/
